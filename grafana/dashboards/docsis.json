{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Virgin Media SuperHub 5 DOCSIS health monitoring",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "docsis_prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ]
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "auto" },
      "title": "Router Status",
      "type": "stat",
      "targets": [{ "datasource": { "uid": "docsis_prometheus" }, "expr": "docsis_router_up", "legendFormat": "Router" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "docsis_prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 } ] }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total Polls",
      "type": "stat",
      "targets": [{ "datasource": { "uid": "docsis_prometheus" }, "expr": "increase(docsis_poll_total[5m])", "legendFormat": "polls/5m" }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "docsis_prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        }
      },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Poll Errors",
      "type": "stat",
      "targets": [{ "datasource": { "uid": "docsis_prometheus" }, "expr": "increase(docsis_poll_errors_total[5m])", "legendFormat": "errors/5m" }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Downstream — Signal Quality",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "docsis_prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "dB",
          "min": 25,
          "max": 45,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 30 },
              { "color": "yellow", "value": 33 },
              { "color": "green",  "value": 36 }
            ]
          },
          "custom": { "lineWidth": 1.5, "fillOpacity": 5, "spanNulls": true }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Downstream SNR per Channel (dB)",
      "type": "timeseries",
      "targets": [{
        "datasource": { "uid": "docsis_prometheus" },
        "expr": "docsis_downstream_snr_db",
        "legendFormat": "Ch {{channel_id}} ({{docsis_version}})"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "docsis_prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "dBm",
          "min": -15,
          "max": 15,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "orange", "value": null },
              { "color": "green",  "value": -7 },
              { "color": "orange", "value": 7 }
            ]
          },
          "custom": { "lineWidth": 1.5, "fillOpacity": 5, "spanNulls": true }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Downstream Power per Channel (dBmV)",
      "type": "timeseries",
      "targets": [{
        "datasource": { "uid": "docsis_prometheus" },
        "expr": "docsis_downstream_power_dbmv",
        "legendFormat": "Ch {{channel_id}}"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "docsis_prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 } ] },
          "custom": { "lineWidth": 1.5, "fillOpacity": 10, "spanNulls": true }
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "id": 12,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Downstream Uncorrectable Errors per Channel",
      "type": "timeseries",
      "targets": [{
        "datasource": { "uid": "docsis_prometheus" },
        "expr": "docsis_downstream_uncorrectables",
        "legendFormat": "Ch {{channel_id}} uncorrectables"
      }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "Upstream — Transmit Power & Ranging",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "docsis_prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "dBm",
          "min": 30,
          "max": 55,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": null },
              { "color": "orange", "value": 38 },
              { "color": "green",  "value": 40 },
              { "color": "orange", "value": 48.5 },
              { "color": "red",    "value": 51 }
            ]
          },
          "custom": { "lineWidth": 1.5, "fillOpacity": 5, "spanNulls": true }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 23 },
      "id": 20,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "Upstream Transmit Power per Channel (dBmV)",
      "type": "timeseries",
      "targets": [{
        "datasource": { "uid": "docsis_prometheus" },
        "expr": "docsis_upstream_power_dbmv",
        "legendFormat": "Ch {{channel_id}} ({{docsis_version}})"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "docsis_prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] },
          "custom": { "lineWidth": 2, "fillOpacity": 20, "spanNulls": true }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 23 },
      "id": 21,
      "options": { "tooltip": { "mode": "multi" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "title": "T3 / T4 Ranging Timeouts",
      "type": "timeseries",
      "targets": [
        { "datasource": { "uid": "docsis_prometheus" }, "expr": "docsis_upstream_t3_timeouts", "legendFormat": "T3 Ch {{channel_id}}" },
        { "datasource": { "uid": "docsis_prometheus" }, "expr": "docsis_upstream_t4_timeouts", "legendFormat": "T4 Ch {{channel_id}}" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 103,
      "title": "Channel Lock Status",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "docsis_prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] },
          "mappings": [ { "options": { "0": { "text": "UNLOCKED" }, "1": { "text": "LOCKED" } }, "type": "value" } ]
        }
      },
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 32 },
      "id": 30,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "horizontal" },
      "title": "Downstream Channel Lock Status",
      "type": "stat",
      "targets": [{ "datasource": { "uid": "docsis_prometheus" }, "expr": "docsis_downstream_locked", "legendFormat": "Ch {{channel_id}}" }]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["docsis", "hub5", "virgin-media"],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "DOCSIS Monitor — SuperHub 5",
  "uid": "docsis-hub5",
  "version": 1
}
