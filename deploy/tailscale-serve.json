{
  "_comment": "Tailscale Serve config — exposes DOCSIS Monitor on your tailnet only.",
  "_usage": "Run: tailscale serve --set-raw - < deploy/tailscale-serve.json",
  "TCP": {
    "443": {
      "HTTPS": true
    }
  },
  "Web": {
    "${TS_CERT_DOMAIN}:443": {
      "Handlers": {
        "/": {
          "Proxy": "http://127.0.0.1:3000"
        }
      }
    }
  }
}
