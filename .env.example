# ── Router ────────────────────────────────────────────────────────────────────
# Modem mode: 192.168.100.1 | Router mode: 192.168.0.1
ROUTER_IP=192.168.100.1
ROUTER_SCHEME=http
POLL_INTERVAL=30
REQUEST_TIMEOUT=10
REQUEST_RETRIES=3

# Optional router auth (most Hub 5 units don't require this)
ROUTER_USER=
ROUTER_PASS=

# ── Alert Thresholds ──────────────────────────────────────────────────────────
SNR_WARN_DB=33.0
SNR_CRIT_DB=30.0
DS_POWER_MIN=-7.0
DS_POWER_MAX=7.0
US_POWER_MIN=38.0
US_POWER_MAX=48.5
UNCORRECTABLE_WARN=100
UNCORRECTABLE_CRIT=500
T3_T4_CRIT_COUNT=1
ALERT_DEBOUNCE_SECONDS=300

# ── Webhook Alerting ──────────────────────────────────────────────────────────
# Comma-separated. Slack, Discord, and custom JSON endpoints are auto-detected.
WEBHOOK_URLS=https://hooks.slack.com/services/XXX,https://discord.com/api/webhooks/YYY

# ── Optional Email ────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_TO=
SMTP_FROM=docsis-monitor@localhost

# ── Storage ───────────────────────────────────────────────────────────────────
DATA_RETENTION_DAYS=90

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false
EXPOSE_PORT=3000

# Optional Basic Auth (leave blank to disable)
BASIC_AUTH_USER=
BASIC_AUTH_PASS=

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASS=change-me-please
