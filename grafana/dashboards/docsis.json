{
  "__inputs": [],
  "__elements": {},
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Virgin Media SuperHub 5 DOCSIS signal health",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "docsis-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "value_and_name", "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "docsis-prometheus" },
          "expr": "docsis_router_up",
          "legendFormat": "Router"
        }
      ],
      "title": "Router Status",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "docsis-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 1 },
              { "color": "red",   "value": 5 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "docsis-prometheus" },
          "expr": "count(docsis_downstream_locked == 1)",
          "legendFormat": "Locked"
        }
      ],
      "title": "DS Channels Locked",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "docsis-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red",   "value": 1 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "docsis-prometheus" },
          "expr": "sum(docsis_upstream_t3_timeouts + docsis_upstream_t4_timeouts)",
          "legendFormat": "T3+T4"
        }
      ],
      "title": "T3/T4 Timeouts (current)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "docsis-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 100 },
              { "color": "red",   "value": 500 }
            ]
          }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "docsis-prometheus" },
          "expr": "sum(docsis_downstream_uncorrectables)",
          "legendFormat": "Uncorrectables"
        }
      ],
      "title": "Total Uncorrectables",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Downstream Signal Quality",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "docsis-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "dB",
          "min": 25,
          "max": 45,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0  },
              { "color": "yellow", "value": 30 },
              { "color": "green",  "value": 33 }
            ]
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 0,
            "showPoints": "never"
          }
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "min", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "docsis-prometheus" },
          "expr": "docsis_downstream_snr_db",
          "legendFormat": "Ch {{channel_id}} ({{docsis_version}})"
        }
      ],
      "title": "DS SNR per Channel (dB)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "docsis-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "dBm",
          "min": -15,
          "max": 15,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": -15 },
              { "color": "yellow", "value": -7  },
              { "color": "green",  "value": -7  },
              { "color": "yellow", "value": 7   },
              { "color": "red",    "value": 15  }
            ]
          },
          "custom": { "lineWidth": 1, "fillOpacity": 0, "showPoints": "never" }
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "min", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "docsis-prometheus" },
          "expr": "docsis_downstream_power_dbmv",
          "legendFormat": "Ch {{channel_id}} ({{docsis_version}})"
        }
      ],
      "title": "DS Power per Channel (dBmV)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "docsis-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "min": 0,
          "custom": { "lineWidth": 1, "fillOpacity": 10, "showPoints": "never", "drawStyle": "bars" }
        }
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 15 },
      "id": 12,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "docsis-prometheus" },
          "expr": "rate(docsis_downstream_uncorrectables[5m])",
          "legendFormat": "Ch {{channel_id}} uncorrectables/s"
        }
      ],
      "title": "DS Uncorrectables Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 102,
      "title": "Upstream Signal",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "docsis-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "dBm",
          "min": 30,
          "max": 55,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",    "value": 0    },
              { "color": "yellow", "value": 38   },
              { "color": "green",  "value": 38   },
              { "color": "yellow", "value": 48.5 },
              { "color": "red",    "value": 55   }
            ]
          },
          "custom": { "lineWidth": 1, "fillOpacity": 0, "showPoints": "never" }
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 23 },
      "id": 20,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "min", "max"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "docsis-prometheus" },
          "expr": "docsis_upstream_power_dbmv",
          "legendFormat": "Ch {{channel_id}} ({{docsis_version}})"
        }
      ],
      "title": "US Transmit Power per Channel (dBmV)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "docsis-prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 20, "showPoints": "auto" }
        }
      },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 23 },
      "id": 21,
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "docsis-prometheus" },
          "expr": "docsis_upstream_t3_timeouts",
          "legendFormat": "Ch {{channel_id}} T3"
        },
        {
          "datasource": { "type": "prometheus", "uid": "docsis-prometheus" },
          "expr": "docsis_upstream_t4_timeouts",
          "legendFormat": "Ch {{channel_id}} T4"
        }
      ],
      "title": "US T3/T4 Timeouts",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["docsis", "cable", "virgin-media"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "DOCSIS Monitor — SuperHub 5",
  "uid": "docsis-superhub5",
  "version": 1
}
